# =============================================================================
# SipSetu — Backend Environment Variables
# =============================================================================
# Copy this file to .env (in the same directory) and fill in your values:
#
#     cp .env.example .env          # macOS / Linux
#     copy .env.example .env         # Windows
#
# DO NOT commit .env to version control. It is already in .gitignore.
# =============================================================================

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# PostgreSQL connection string.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# The database must already exist (create it with: createdb sipsetu).
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD_HERE@localhost:5432/sipsetu

# ---------------------------------------------------------------------------
# Authentication (JWT)
# ---------------------------------------------------------------------------
# A strong, random secret used to sign JSON Web Tokens.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-this-to-a-long-random-secret-in-production

# ---------------------------------------------------------------------------
# Frontend URL
# ---------------------------------------------------------------------------
# The URL of the running frontend. Used to build email verification links
# and CORS headers. Change to your deployed URL in production.
FRONTEND_URL=http://localhost:5173

# ---------------------------------------------------------------------------
# SMTP — Email Sending
# ---------------------------------------------------------------------------
# When SMTP_HOST and SMTP_PORT are both set, the app sends real emails via
# the configured SMTP server. If left unset (or empty), emails are printed
# to the server's terminal stderr — useful for local development.
#
# For Gmail (App Password required):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=your.email@gmail.com
#   SMTP_PASSWORD=your-16-char-app-password
#
# For Mailtrap (development/testing):
#   SMTP_HOST=sandbox.smtp.mailtrap.io
#   SMTP_PORT=2525
#   SMTP_USER=your-mailtrap-username
#   SMTP_PASSWORD=your-mailtrap-password

SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=

# Whether to use STARTTLS for the SMTP connection. Set to "false" for
# plain-text connections. Defaults to "true" when unset.
# Acceptable values: true, false, 1, 0, yes, no
SMTP_USE_TLS=true

# "From" address shown on outgoing emails. Defaults to noreply@sipsetu.com.
SMTP_FROM=noreply@sipsetu.com

# =============================================================================
# NOTES
# =============================================================================
# All variables have sensible defaults in config.py so the app can start
# without any .env file. At minimum, set DATABASE_URL and JWT_SECRET_KEY
# before going to production.
